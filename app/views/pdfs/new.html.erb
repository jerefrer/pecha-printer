<%# Theme + locale toggles — floating top-right %>
<div class="fixed top-4 right-4 z-30 flex items-center gap-2">
  <%= link_to url_for(locale: (I18n.locale == :en ? :fr : :en)),
        class: "lang-toggle",
        aria: { label: t("locale.switch_aria") } do %>
    <%= I18n.locale == :en ? "FR" : "EN" %>
  <% end %>
  <div data-controller="theme">
    <button type="button"
            class="theme-toggle"
            data-action="click->theme#toggle"
            aria-label="<%= t('theme.toggle_aria') %>">
      <span class="hidden dark:inline-flex">
        <%= lucide_icon "sun", class: "w-4 h-4" %>
      </span>
      <span class="inline-flex dark:hidden">
        <%= lucide_icon "moon", class: "w-4 h-4" %>
      </span>
    </button>
  </div>
</div>

<div class="min-h-screen flex justify-center [.has-preview_&]:justify-start p-6 lg:p-10">
  <div class="flex gap-8 items-start w-full max-w-[760px] [.has-preview_&]:max-w-none">
    <div class="flex flex-col gap-8 w-full [.has-preview_&]:max-w-[400px] [.has-preview_&]:h-[calc(100vh-5rem)] [.has-preview_&]:overflow-y-auto [.has-preview_&]:pr-2">
      <header class="text-center [.has-preview_&]:text-left animate-fade-in">
        <h1 class="m-0 text-4xl font-bold tracking-tight [.has-preview_&]:text-2xl"><%= t("app.title") %></h1>
        <p class="mt-3 text-ink-muted text-base [.has-preview_&]:hidden">
          <%= t("app.tagline") %>
        </p>
      </header>

      <%= form_for @pdf, multipart: true,
            html: { class: "flex flex-col gap-6" },
            data: {
              controller: "margins preset dropzone custom-panel",
              action: "submit->margins#submitForm",
              preset_persisted_value: @pdf.persisted?
            } do |form| %>

        <%= form.hidden_field :sheet_margins, data: { margins_target: "form" } %>

        <%# Drop zone or file chip %>
        <% if @pdf.persisted? %>
          <div class="card flex items-center gap-3 px-4 py-3 animate-chip-in">
            <%= lucide_icon "file-text", class: "w-5 h-5 text-accent shrink-0" %>
            <span class="flex-1 font-semibold text-sm break-all"><%= @pdf.file.identifier %></span>
            <%= link_to new_pdf_path,
                  class: "w-8 h-8 inline-flex items-center justify-center rounded-md text-ink-muted hover:text-red-600 hover:bg-canvas-hover transition-colors",
                  aria: { label: t("chip.replace_aria") } do %>
              <%= lucide_icon "x", class: "w-4 h-4" %>
            <% end %>
          </div>
        <% else %>
          <div data-dropzone-target="dropzone" class="dropzone">
            <%= lucide_icon "upload-cloud", class: "w-8 h-8 dropzone-icon animate-float" %>
            <div class="text-base font-semibold mt-1"><%= t("dropzone.primary") %></div>
            <div class="text-xs text-ink-muted"><%= t("dropzone.secondary") %></div>
            <%= form.file_field :file,
                  accept: "application/pdf",
                  class: "absolute inset-0 opacity-0 cursor-pointer",
                  data: { dropzone_target: "fileInput" } %>
          </div>

          <div class="card flex items-center gap-3 px-4 py-3 animate-chip-in"
               data-dropzone-target="chip" hidden>
            <%= lucide_icon "file-text", class: "w-5 h-5 text-accent shrink-0" %>
            <span class="flex-1 font-semibold text-sm break-all" data-dropzone-target="chipName"></span>
            <span class="text-xs text-ink-muted shrink-0" data-dropzone-target="chipSize"></span>
            <button type="button"
                    class="w-8 h-8 inline-flex items-center justify-center rounded-md text-ink-muted hover:text-red-600 hover:bg-canvas-hover transition-colors"
                    data-action="click->dropzone#remove"
                    aria-label="<%= t('chip.remove_aria') %>">
              <%= lucide_icon "x", class: "w-4 h-4" %>
            </button>
          </div>
        <% end %>

        <%# Preset cards %>
        <div class="flex flex-col gap-3">
          <div class="text-center text-sm text-ink-muted font-medium"><%= t("presets.label") %></div>
          <div class="grid grid-cols-1 sm:grid-cols-3 [.has-preview_&]:sm:grid-cols-1 gap-3">
            <% [
              { name: "standard_a4", title: t("presets.standard_a4.title"), specs: [t("presets.specs.three_per_sheet"), t("presets.specs.fit_to_paper"), t("presets.specs.duplex")] },
              { name: "standard_a3", title: t("presets.standard_a3.title"), specs: [t("presets.specs.three_per_sheet"), t("presets.specs.fit_to_paper"), t("presets.specs.duplex")] },
              { name: "shechen", title: t("presets.shechen.title"), specs: [t("presets.specs.a3_three_per_sheet"), t("presets.specs.crop_marks"), t("presets.specs.duplex")], badge: t("presets.shechen.badge") }
            ].each_with_index do |p, idx| %>
              <div role="button"
                   tabindex="0"
                   class="preset animate-preset-in focus-visible:ring-2 focus-visible:ring-accent"
                   style="animation-delay: <%= 60 * (idx + 1) %>ms;"
                   data-preset-name="<%= p[:name] %>"
                   data-preset-target="card"
                   data-action="click->preset#select keydown->preset#selectKeydown">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="preset__title"><%= p[:title] %></span>
                  <% if p[:badge] %>
                    <span class="preset__badge"><%= p[:badge] %></span>
                  <% end %>
                </div>
                <ul class="preset__specs mt-2">
                  <% p[:specs].each do |s| %><li><%= s %></li><% end %>
                </ul>
                <% if p[:name] == "shechen" %>
                  <div class="preset__hint">
                    <div><%= t("presets.shechen.hint") %></div>
                    <button type="button" data-action="click->preset#toggleHelp">
                      <%= t("presets.shechen.help_link") %>
                    </button>
                  </div>
                  <div class="popover" data-preset-target="popover" hidden>
                    <h4 class="m-0 mb-2 text-sm font-semibold"><%= t("presets.shechen.popover_title") %></h4>
                    <p class="m-0 mb-3 text-[13px] leading-snug text-ink-muted">
                      <%= raw t("presets.shechen.popover_body_html") %>
                    </p>
                    <%= image_tag "tibetdoc-shechen-config.png",
                          alt: t("presets.shechen.popover_title"),
                          class: "w-full rounded border border-canvas-border" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <%# Custom panel toggle %>
        <div class="flex justify-center">
          <button type="button"
                  class="custom-toggle"
                  aria-expanded="false"
                  data-custom-panel-target="toggle"
                  data-action="click->custom-panel#toggle">
            <%= lucide_icon "sliders-horizontal", class: "w-4 h-4" %>
            <span><%= t("custom.toggle") %></span>
            <%= lucide_icon "chevron-down", class: "w-4 h-4 transition-transform duration-200", data: { custom_panel_target: "chevron" } %>
          </button>
        </div>

        <%# Custom panel body %>
        <div class="overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out [&.is-open]:max-h-[2000px]"
             data-custom-panel-target="panel"
             aria-hidden="true">
          <div class="card p-6 flex flex-col gap-6">

            <section>
              <h3 class="group-title"><%= t("custom.paper.title") %></h3>
              <div class="flex flex-col gap-4">
                <div>
                  <div class="field-label"><%= t("custom.paper.size") %></div>
                  <div class="flex flex-wrap gap-1 segmented">
                    <%= form.radio_button :paper_size, 'A4', id: "pdf_paper_size_a4" %>
                    <%= form.label :paper_size_a4, 'A4' %>
                    <%= form.radio_button :paper_size, 'A3', id: "pdf_paper_size_a3" %>
                    <%= form.label :paper_size_a3, 'A3' %>
                  </div>
                </div>
                <div>
                  <div class="field-label"><%= t("custom.paper.orientation") %></div>
                  <div class="flex flex-wrap gap-1 segmented">
                    <%= form.radio_button :portrait, false, id: "pdf_portrait_no" %>
                    <%= form.label :portrait_no, t("custom.paper.landscape") %>
                    <%= form.radio_button :portrait, true, id: "pdf_portrait_yes" %>
                    <%= form.label :portrait_yes, t("custom.paper.portrait") %>
                  </div>
                </div>
              </div>
            </section>

            <section>
              <h3 class="group-title"><%= t("custom.layout.title") %></h3>
              <div class="flex flex-col gap-4">
                <div>
                  <div class="field-label"><%= t("custom.layout.pages_per_sheet") %></div>
                  <div class="flex flex-wrap gap-1 segmented">
                    <% %w[2 3 4 5 6 7 8].each do |n| %>
                      <%= form.radio_button :pages_per_sheet, n, id: "pdf_pages_per_sheet_#{n}" %>
                      <%= form.label "pages_per_sheet_#{n}".to_sym, n %>
                    <% end %>
                  </div>
                </div>
                <div>
                  <div class="field-label"><%= t("custom.layout.autoscale") %></div>
                  <div class="flex flex-wrap gap-1 segmented">
                    <%= form.radio_button :autoscale, 'none', id: "pdf_autoscale_none" %>
                    <%= form.label :autoscale_none, t("custom.layout.autoscale_none") %>
                    <%= form.radio_button :autoscale, 'pdfjam', id: "pdf_autoscale_pdfjam" %>
                    <%= form.label :autoscale_pdfjam, t("custom.layout.autoscale_fit") %>
                    <%= form.radio_button :autoscale, 'podofo', id: "pdf_autoscale_podofo" %>
                    <%= form.label :autoscale_podofo, t("custom.layout.autoscale_crop") %>
                  </div>
                </div>
                <label class="inline-flex items-center gap-2 text-sm cursor-pointer text-ink">
                  <%= form.check_box :two_sided_flipped, { id: 'pdf_two_sided_flipped', class: 'w-[18px] h-[18px] accent-accent' }, '1', '0' %>
                  <span><%= t("custom.layout.flip_label") %></span>
                </label>
                <label class="inline-flex items-center gap-2 text-sm cursor-pointer text-ink">
                  <%= form.check_box :crop_from_marks, { id: 'pdf_crop_from_marks', class: 'w-[18px] h-[18px] accent-accent' }, '1', '0' %>
                  <span><%= t("custom.layout.crop_marks_label") %></span>
                </label>
              </div>
            </section>

            <section class="margins-section">
              <h3 class="group-title"><%= t("custom.margins.title") %></h3>
              <div class="flex flex-wrap gap-1 mb-3 segmented">
                <%= form.radio_button :sheet_margin_mode, 'none', class: 'margin-mode-radio', id: 'pdf_sheet_margin_mode_none', data: { action: "change->margins#updateMode", margins_target: "mode" } %>
                <%= form.label :sheet_margin_mode_none, t("custom.margins.none") %>
                <%= form.radio_button :sheet_margin_mode, 'all', class: 'margin-mode-radio', id: 'pdf_sheet_margin_mode_all', data: { action: "change->margins#updateMode", margins_target: "mode" } %>
                <%= form.label :sheet_margin_mode_all, t("custom.margins.all") %>
                <%= form.radio_button :sheet_margin_mode, 'horizontal_vertical', checked: true, class: 'margin-mode-radio', id: 'pdf_sheet_margin_mode_horizontal_vertical', data: { action: "change->margins#updateMode", margins_target: "mode" } %>
                <%= form.label :sheet_margin_mode_horizontal_vertical, t("custom.margins.hv") %>
                <%= form.radio_button :sheet_margin_mode, 'custom', class: 'margin-mode-radio', id: 'pdf_sheet_margin_mode_custom', data: { action: "change->margins#updateMode", margins_target: "mode" } %>
                <%= form.label :sheet_margin_mode_custom, t("custom.margins.custom") %>
              </div>

              <div class="mt-2" data-margins-target="inputs">
                <small class="block text-xs text-ink-muted mb-3"><%= t("custom.margins.help") %></small>
                <div data-margins-target="all">
                  <label for="pdf_sheet_margin_all" class="field-label"><%= t("custom.margins.all_label") %></label>
                  <%= form.number_field :sheet_margin_all, step: 'any', placeholder: '0mm', class: 'margin-input', data: { target: 'all' } %>
                </div>
                <div data-margins-target="hv">
                  <div class="flex gap-6">
                    <div>
                      <label for="pdf_sheet_margin_horizontal" class="field-label"><%= t("custom.margins.lr") %></label>
                      <%= form.number_field :sheet_margin_horizontal, step: 'any', placeholder: '0mm', value: 0, class: 'margin-input', data: { target: 'horizontal' } %>
                    </div>
                    <div>
                      <label for="pdf_sheet_margin_vertical" class="field-label"><%= t("custom.margins.tb") %></label>
                      <%= form.number_field :sheet_margin_vertical, step: 'any', placeholder: '0mm', value: -5, class: 'margin-input', data: { target: 'vertical' } %>
                    </div>
                  </div>
                </div>
                <div data-margins-target="custom">
                  <div class="margin-custom-grid">
                    <div></div>
                    <%= form.number_field :sheet_margin_top, step: 'any', placeholder: '0mm', class: 'margin-input', data: { target: 'top' } %>
                    <div></div>
                    <%= form.number_field :sheet_margin_left, step: 'any', placeholder: '0mm', class: 'margin-input', data: { target: 'left' } %>
                    <div></div>
                    <%= form.number_field :sheet_margin_right, step: 'any', placeholder: '0mm', class: 'margin-input', data: { target: 'right' } %>
                    <div></div>
                    <%= form.number_field :sheet_margin_bottom, step: 'any', placeholder: '0mm', class: 'margin-input', data: { target: 'bottom' } %>
                    <div></div>
                  </div>
                </div>
              </div>
            </section>

          </div>
        </div>

        <%# CTA %>
        <% if @pdf.persisted? %>
          <div class="flex flex-col gap-3 animate-cta-in mt-2">
            <%= link_to download_pdf_path(@pdf), download: true, class: "btn-success" do %>
              <%= lucide_icon "download", class: "w-5 h-5" %>
              <%= t("cta.download") %>
            <% end %>
            <%= form.submit "↻ #{t('cta.regenerate')}", class: "btn-ghost" %>
          </div>
        <% else %>
          <div class="flex flex-col gap-3 animate-cta-in mt-2">
            <button type="submit" class="btn-primary">
              <%= lucide_icon "sparkles", class: "w-5 h-5" %>
              <%= t("cta.generate") %>
            </button>
          </div>
        <% end %>

      <% end %>
    </div>

    <% if @pdf.persisted? %>
      <div class="flex-1 min-w-0 h-[calc(100vh-5rem)] min-h-[600px] rounded-[5px] border border-canvas-border bg-canvas-surface shadow-card overflow-hidden animate-preview-in">
        <embed src="<%= download_pdf_path(@pdf) %>#toolbar=0"
               type="application/pdf"
               class="block w-full h-full border-0" />
      </div>
    <% end %>
  </div>
</div>

<% if @pdf.persisted? %>
  <script>document.body.classList.add("has-preview");</script>
<% end %>
